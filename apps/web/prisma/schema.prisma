generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------------
// MULTI-TENANCY CORE
// --------------------------------------------------------

model School {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  website     String?
  mpesa_paybill String? // For payment integration
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       User[]
  students    Student[]
  parents     Parent[]
  staff       Staff[]
  classes     Class[]
  exams       Exam[]
  invoices    Invoice[]
  payments    Payment[]
  ledger      LedgerEntry[]
  subjects    Subject[]
  terms       Term[]
  academic_years AcademicYear[]
  grade_levels GradeLevel[]
  fee_structures FeeStructure[]
  grading_systems GradingSystem[]
  rooms       Room[]
  timetable_slots TimetableSlot[]
  admission_applications AdmissionApplication[]
  payroll_records PayrollRecord[]
  assets          Asset[]
  stock_items     StockItem[]
  books           Book[]
  transport_routes TransportRoute[]
  vehicles        Vehicle[]
  hostels         Hostel[]
  discipline_records DisciplineRecord[]
  calendar_events    CalendarEvent[]
  visitors           Visitor[]
  clinic_visits      ClinicVisit[]
  assignments        Assignment[]
  resources          Resource[]
  alumni             Alumnus[]
  expenses           Expense[]

  @@map("schools")
}

model AcademicYear {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  name        String   // e.g. "2024"
  start_date  DateTime
  end_date    DateTime
  is_active   Boolean  @default(false)

  terms       Term[]

  @@index([school_id])
  @@map("academic_years")
}

model Room {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  name        String   // e.g. "Lab 1", "Room 101"
  capacity    Int?

  slots       TimetableSlot[]

  @@index([school_id])
  @@map("rooms")
}

model TimetableSlot {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  class_id    String
  class       Class    @relation(fields: [class_id], references: [id])
  
  subject_id  String
  subject     Subject  @relation(fields: [subject_id], references: [id])
  
  teacher_id  String?
  teacher     Staff?   @relation(fields: [teacher_id], references: [id])
  
  room_id     String?
  room        Room?    @relation(fields: [room_id], references: [id])

  day_of_week Int      // 1-7 (Mon-Sun)
  start_time  String   // HH:mm (e.g. "08:00")
  end_time    String   // HH:mm (e.g. "09:00")

  @@map("timetable_slots")
}

model GradingSystem {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  name        String   // e.g. "Standard Grading"
  
  grades      GradeBoundary[]
  exams       Exam[]

  @@index([school_id])
  @@map("grading_systems")
}

model GradeBoundary {
  id                String   @id @default(uuid())
  grading_system_id String
  grading_system    GradingSystem @relation(fields: [grading_system_id], references: [id])
  
  grade             String   // e.g. "A"
  min_score         Float
  max_score         Float
  remarks           String?

  @@map("grade_boundaries")
}

// --------------------------------------------------------
// IDENTITY & RBAC
// --------------------------------------------------------

enum Role {
  SUPER_ADMIN // Platform owner
  SCHOOL_ADMIN // Principal/Admin
  TEACHER
  PARENT
  STUDENT
  ACCOUNTANT
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // Argon2 hash
  first_name  String
  last_name   String
  phone       String?
  role        Role     @default(STUDENT)
  is_active   Boolean  @default(true)
  
  school_id   String?
  school      School?  @relation(fields: [school_id], references: [id])

  // Profile links
  student     Student?
  parent      Parent?
  staff       Staff?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("users")
}

// --------------------------------------------------------
// PROFILES
// --------------------------------------------------------

model Student {
  id              String   @id @default(uuid())
  user_id         String   @unique
  user            User     @relation(fields: [user_id], references: [id])
  school_id       String
  school          School   @relation(fields: [school_id], references: [id])
  
  admission_no    String
  dob             DateTime?
  gender          String?
  
  class_id        String?
  class           Class?   @relation(fields: [class_id], references: [id])
  
  parent_id       String?
  parent          Parent?  @relation(fields: [parent_id], references: [id])

  attendance      Attendance[]
  results         Result[]
  invoices        Invoice[]
  borrow_records  BorrowRecord[]
  
  transport_route_id String?
  transport_route    TransportRoute? @relation(fields: [transport_route_id], references: [id])

  dorm_room_id    String?
  dorm_room       DormRoom? @relation(fields: [dorm_room_id], references: [id])
  discipline_records DisciplineRecord[]
  medical_record     MedicalRecord?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([school_id, admission_no]) // Unique admission number per school
  @@index([school_id])
  @@map("students")
}

model Parent {
  id          String   @id @default(uuid())
  user_id     String   @unique
  user        User     @relation(fields: [user_id], references: [id])
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])

  students    Student[]
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("parents")
}

model Staff {
  id          String   @id @default(uuid())
  user_id     String   @unique
  user        User     @relation(fields: [user_id], references: [id])
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])

  department  String?
  designation String?
  base_salary Decimal? @db.Decimal(10, 2)
  id_number   String?  @unique
  joining_date DateTime @default(now())

  classes_managed Class[] // Form teacher
  subjects_taught Subject[] @relation("SubjectTeachers")
  timetable_slots TimetableSlot[]
  payroll_records PayrollRecord[]
  leaves          LeaveRequest[]
  vehicle         Vehicle[]
  reported_discipline DisciplineRecord[]
  clinic_visits       ClinicVisit[]
  recorded_expenses   Expense[] @relation("RecordedExpenses")

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("staff")
}

model PayrollRecord {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  staff_id    String
  staff       Staff    @relation(fields: [staff_id], references: [id])

  month       Int      // 1-12
  year        Int
  base_pay    Decimal  @db.Decimal(10, 2)
  deductions  Decimal  @db.Decimal(10, 2) @default(0)
  net_pay     Decimal  @db.Decimal(10, 2)
  status      String   @default("DRAFT") // DRAFT, PAID
  paid_at     DateTime?

  @@unique([staff_id, month, year])
  @@map("payroll_records")
}

model LeaveRequest {
  id          String   @id @default(uuid())
  staff_id    String
  staff       Staff    @relation(fields: [staff_id], references: [id])
  
  type        String   // SICK, ANNUAL, PERSONAL
  start_date  DateTime
  end_date    DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?

  created_at  DateTime @default(now())
  @@map("leave_requests")
}

enum AssetStatus {
  OPERATIONAL
  UNDER_REPAIR
  RETIRED
  LOST
}

model Asset {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  name        String   // e.g. "Dell Latitude 5400"
  category    String   // e.g. "ELECTRONICS", "FURNITURE"
  serial_no   String?  @unique
  purchase_date DateTime?
  cost        Decimal? @db.Decimal(10, 2)
  status      AssetStatus @default(OPERATIONAL)
  location    String?  // e.g. "Lab 1", "Office"

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("assets")
}

model StockItem {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  name        String   // e.g. "A4 Printing Paper"
  category    String   // e.g. "STATIONERY"
  quantity    Int      @default(0)
  min_quantity Int     @default(5) // For low-stock alerts
  unit        String   // e.g. "Reams", "Boxes"

  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("stock_items")
}

model Book {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  title       String
  author      String?
  isbn        String?
  category    String?  // e.g. "Fiction", "Science"
  
  copies      BookCopy[]

  created_at  DateTime @default(now())
  @@index([school_id])
  @@map("books")
}

model BookCopy {
  id          String   @id @default(uuid())
  book_id     String
  book        Book     @relation(fields: [book_id], references: [id])
  
  barcode     String   @unique
  status      String   @default("AVAILABLE") // AVAILABLE, BORROWED, LOST
  
  borrow_records BorrowRecord[]

  @@map("book_copies")
}

model BorrowRecord {
  id          String   @id @default(uuid())
  copy_id     String
  copy        BookCopy @relation(fields: [copy_id], references: [id])
  
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])
  
  borrow_date DateTime @default(now())
  due_date    DateTime
  return_date DateTime?
  status      String   @default("BORROWED") // BORROWED, RETURNED, OVERDUE

  @@map("borrow_records")
}

model TransportRoute {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  name        String   // e.g. "Westlands - Route A"
  cost        Decimal  @db.Decimal(10, 2)
  stops       String?  // Comma-separated stops

  vehicles    Vehicle[]
  students    Student[]

  @@index([school_id])
  @@map("transport_routes")
}

model Vehicle {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  reg_number  String   @unique
  capacity    Int
  
  driver_id   String?
  driver      Staff?   @relation(fields: [driver_id], references: [id])
  
  route_id    String?
  route       TransportRoute? @relation(fields: [route_id], references: [id])

  @@index([school_id])
  @@map("vehicles")
}

model Hostel {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  name        String   // e.g. "Jupiter House", "Mandela Hall"
  type        String   // BOYS, GIRLS, MIXED
  description String?

  rooms       DormRoom[]

  @@index([school_id])
  @@map("hostels")
}

model DormRoom {
  id          String   @id @default(uuid())
  hostel_id   String
  hostel      Hostel   @relation(fields: [hostel_id], references: [id])
  
  room_number String
  capacity    Int      // Total beds
  
  students    Student[]

  @@map("dorm_rooms")
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model DisciplineRecord {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])
  
  title       String   // e.g. "Late for class", "Fighting"
  description String?
  severity    IncidentSeverity @default(LOW)
  action_taken String? // e.g. "Verbal warning", "Suspension"
  
  reported_by_id String?
  reported_by    Staff?  @relation(fields: [reported_by_id], references: [id])
  
  incident_date DateTime @default(now())
  created_at    DateTime @default(now())

  @@index([school_id])
  @@map("discipline_records")
}

model Visitor {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  full_name   String
  id_number   String?
  phone       String?
  email       String?
  
  visits      VisitRecord[]

  created_at  DateTime @default(now())
  @@index([school_id])
  @@map("visitors")
}

model VisitRecord {
  id          String   @id @default(uuid())
  visitor_id  String
  visitor     Visitor  @relation(fields: [visitor_id], references: [id])
  
  purpose     String   // e.g. "Parent Meeting", "Delivery"
  whom_to_see String?
  
  check_in    DateTime @default(now())
  check_out   DateTime?
  
  status      String   @default("IN_CAMPUS") // IN_CAMPUS, CHECKED_OUT

  @@map("visit_records")
}

model MedicalRecord {
  id          String   @id @default(uuid())
  student_id  String   @unique
  student     Student  @relation(fields: [student_id], references: [id])
  
  blood_group String?
  allergies   String?  // Comma separated
  conditions  String?  // Chronic conditions
  emergency_contact String?
  
  visits      ClinicVisit[]

  updated_at  DateTime @updatedAt
  @@map("medical_records")
}

model ClinicVisit {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  medical_record_id String
  medical_record    MedicalRecord @relation(fields: [medical_record_id], references: [id])
  
  visit_date  DateTime @default(now())
  symptoms    String
  diagnosis   String?
  treatment   String?
  notes       String?
  
  attended_by_id String?
  attended_by    Staff? @relation(fields: [attended_by_id], references: [id])

  @@index([school_id])
  @@map("clinic_visits")
}

model Assignment {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  class_id    String
  class       Class    @relation(fields: [class_id], references: [id])
  
  subject_id  String
  subject     Subject  @relation(fields: [subject_id], references: [id])
  
  title       String
  description String?
  due_date    DateTime
  
  created_at  DateTime @default(now())
  @@index([school_id])
  @@map("assignments")
}

model Resource {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  title       String
  file_url    String?
  category    String? // NOTES, VIDEO, EBOOK
  
  subject_id  String?
  subject     Subject? @relation(fields: [subject_id], references: [id])

  created_at  DateTime @default(now())
  @@index([school_id])
  @@map("resources")
}

model Alumnus {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  first_name  String
  last_name   String
  email       String?
  phone       String?
  graduation_year Int
  
  current_occupation String?
  employer           String?
  university         String?
  
  notes       String?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("alumni")
}

model Expense {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  title       String   // e.g. "Electricity Bill - March"
  category    String   // UTILITIES, MAINTENANCE, SUPPLIES, SALARY
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  
  recorded_by_id String?
  recorded_by    Staff? @relation("RecordedExpenses", fields: [recorded_by_id], references: [id])
  
  receipt_url String?
  notes       String?

  created_at  DateTime @default(now())
  @@index([school_id])
  @@map("expenses")
}

enum EventCategory {
  ACADEMIC
  HOLIDAY
  SPORTS
  EXAM
  OTHER
}

model CalendarEvent {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  title       String
  description String?
  start_date  DateTime
  end_date    DateTime
  category    EventCategory @default(OTHER)
  is_all_day  Boolean  @default(false)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("calendar_events")
}

// --------------------------------------------------------
// ACADEMIC STRUCTURE
// --------------------------------------------------------

model Term {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  academic_year_id String?
  academic_year    AcademicYear? @relation(fields: [academic_year_id], references: [id])
  
  name        String   // e.g. "Term 1"
  start_date  DateTime
  end_date    DateTime
  is_active   Boolean  @default(false)

  exams       Exam[]
  classes     Class[] 
  fee_structures FeeStructure[]

  @@index([school_id])
  @@map("terms")
}

model GradeLevel {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  name        String   // e.g., "Grade 1", "Form 4"
  level       Int      // Numeric order for sorting

  classes     Class[]
  fee_structures FeeStructure[]
  admission_applications AdmissionApplication[]

  @@index([school_id])
  @@map("grade_levels")
}

model Class {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  grade_id    String
  grade       GradeLevel @relation(fields: [grade_id], references: [id])
  
  name        String   // e.g. "East" or "West"
  
  term_id     String?
  term        Term?    @relation(fields: [term_id], references: [id])

  form_teacher_id String?
  form_teacher    Staff?  @relation(fields: [form_teacher_id], references: [id])

  students    Student[]
  attendance  Attendance[]
  subjects    Subject[] @relation("ClassSubjects") // Subjects taught in this class
  timetable_slots TimetableSlot[]
  assignments     Assignment[]

  @@index([school_id])
  @@map("classes")
}

model Subject {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  name        String   // e.g. "Mathematics"
  code        String?  // e.g. "MATH101"
  
  classes     Class[]  @relation("ClassSubjects") // Many-to-many implicit
  teachers    Staff[]  @relation("SubjectTeachers") // Many-to-many implicit
  exams       Exam[]
  timetable_slots TimetableSlot[]
  assignments     Assignment[]
  resources       Resource[]

  @@index([school_id])
  @@map("subjects")
}

// --------------------------------------------------------
// EXAMS & RESULTS
// --------------------------------------------------------

model Exam {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  term_id     String
  term        Term     @relation(fields: [term_id], references: [id])
  subject_id  String
  subject     Subject  @relation(fields: [subject_id], references: [id])
  
  grading_system_id String?
  grading_system    GradingSystem? @relation(fields: [grading_system_id], references: [id])

  name        String   // e.g. "Mid-Term Exam"
  date        DateTime
  max_marks   Int      @default(100)

  results     Result[]

  @@index([school_id])
  @@map("exams")
}

model Result {
  id          String   @id @default(uuid())
  exam_id     String
  exam        Exam     @relation(fields: [exam_id], references: [id])
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])
  
  marks_obtained Float
  grade          String? // e.g. "A", "B+"
  remarks        String?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([exam_id, student_id])
  @@map("results")
}

// --------------------------------------------------------
// ATTENDANCE
// --------------------------------------------------------

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AdmissionStatus {
  PENDING
  REVIEWING
  INTERVIEW_SCHEDULED
  ACCEPTED
  REJECTED
  ENROLLED
}

model AdmissionApplication {
  id              String   @id @default(uuid())
  school_id       String
  school          School   @relation(fields: [school_id], references: [id])
  
  first_name      String
  last_name       String
  email           String
  phone           String
  
  applied_grade_id String
  applied_grade    GradeLevel @relation(fields: [applied_grade_id], references: [id])
  
  status          AdmissionStatus @default(PENDING)
  notes           String?
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([school_id])
  @@map("admission_applications")
}

model Attendance {
  id          String   @id @default(uuid())
  school_id   String // Denormalized for easier querying
  date        DateTime @db.Date
  
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])
  
  class_id    String
  class       Class    @relation(fields: [class_id], references: [id])
  
  status      AttendanceStatus
  remarks     String?

  @@unique([student_id, date]) // One record per student per day
  @@index([school_id, date])
  @@map("attendance")
}

// --------------------------------------------------------
// FINANCE (FEE STRUCTURES & LEDGER)
// --------------------------------------------------------

enum PaymentMethod {
  MPESA
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model FeeStructure {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  grade_id    String
  grade       GradeLevel @relation(fields: [grade_id], references: [id])
  term_id     String
  term        Term     @relation(fields: [term_id], references: [id])
  
  items       FeeItem[]
  
  total_amount Decimal @db.Decimal(10, 2)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([grade_id, term_id])
  @@map("fee_structures")
}

model FeeItem {
  id          String   @id @default(uuid())
  fee_structure_id String
  fee_structure    FeeStructure @relation(fields: [fee_structure_id], references: [id])
  
  name        String   // e.g., "Tuition", "Transport", "Activity"
  amount      Decimal  @db.Decimal(10, 2)
  is_optional Boolean  @default(false)

  @@map("fee_items")
}

model Invoice {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])

  title       String   // e.g. "Term 1 Tuition"
  amount      Decimal  @db.Decimal(10, 2)
  due_date    DateTime
  status      String   @default("UNPAID") // UNPAID, PARTIAL, PAID

  items       Json?    // Snapshot of FeeItems applied
  
  payments    Payment[] // Payments linked to this invoice
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([school_id])
  @@map("invoices")
}

model Payment {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  
  amount      Decimal  @db.Decimal(10, 2)
  method      PaymentMethod
  reference   String?  // M-Pesa Receipt Number or Cheque No
  status      PaymentStatus @default(PENDING)
  
  // M-Pesa specific fields
  mpesa_receipt String? @unique
  phone_number  String?
  
  invoice_id  String?
  invoice     Invoice? @relation(fields: [invoice_id], references: [id])
  
  created_at  DateTime @default(now())

  @@index([school_id])
  @@map("payments")
}

model LedgerEntry {
  id          String   @id @default(uuid())
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])

  description String
  amount      Decimal  @db.Decimal(10, 2)
  type        String   // DEBIT or CREDIT
  category    String   // TUITION, EXAM_FEE, TRANSPORT, PAYMENT
  
  transaction_date DateTime @default(now())
  
  reference_id String? // Link to Invoice ID or Payment ID

  @@index([school_id])
  @@map("ledger_entries")
}
